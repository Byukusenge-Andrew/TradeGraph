{
  "Jwt": {
    "Key": "<YOUR_SUPER_SECRET_JWT_KEY>"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-api": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "fixed",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "catalog-suppliers-api": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "fixed",
        "Match": { "Path": "/api/suppliers/{**catch-all}" }
      },
      "catalog-retailers-api": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "fixed",
        "Match": { "Path": "/api/retailers/{**catch-all}" }
      },
      "catalog-pricing-api": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "fixed",
        "Match": { "Path": "/api/pricing/{**catch-all}" }
      },
      "graph-api": {
        "ClusterId": "graph-cluster",
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "fixed",
        "Match": { "Path": "/api/graph/{**catch-all}" }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "graph-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002/"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  }
}
