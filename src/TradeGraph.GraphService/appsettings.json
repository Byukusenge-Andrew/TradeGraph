{
  "ConnectionStrings": {
    "Neo4j": "bolt://localhost:7687",
    "Neo4jUser": "<YOUR_NEO4J_USER>",
    "Neo4jPassword": "<YOUR_NEO4J_PASSWORD>",
    "Redis": "<YOUR_VALKEY_URL>,password=<YOUR_VALKEY_PASSWORD>,user=default,ssl=True,abortConnect=False"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5002",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://localhost:5012",
        "Protocols": "Http2"
      }
    }
  }
}
