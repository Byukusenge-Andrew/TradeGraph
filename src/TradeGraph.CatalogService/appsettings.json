{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=tradegraph_catalog;Username=<YOUR_PG_USER>;Password=<YOUR_PG_PASSWORD>",
    "Redis": "<YOUR_VALKEY_URL>,password=<YOUR_VALKEY_PASSWORD>,user=default,ssl=True,abortConnect=False"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5001",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://localhost:5011",
        "Protocols": "Http2"
      }
    }
  }
}
